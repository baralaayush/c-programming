//wap to sorting 2d array in ascending
#include<stdio.h>
int main()
{
	int i,j,k,l,row,col,temp;
	printf("Enter the size for 2d array:\n");
	scanf("%d%d",&row,&col);
	int mat[row][col];
	printf("Enter an element for an array:\n");
	for(i=0; i<row; i++)
	{
		for(j=0; j<col; j++)
		{
			scanf("%d",&mat[i][j]);
		}
	}
	
	//process
	for(i=0; i<row; i++)
	{
		for(j=0; j<col; j++)
		{
			for(k=0; k<row; k++)
			{
				for(l=0; l<col; l++)
				{
					if(mat[i][j]<mat[k][l])
					{
					temp=mat[i][j];
		  			mat[i][j]=mat[k][l];
		  			mat[k][l]=temp;
						
					}
					
				}
			}
		}
	}
	
	//print
	printf("The sorting is:\n");
	for(i=0; i<row; i++)
	{
		for(j=0; j<col; j++)
		{
			printf("%d\t",mat[i][j]);
		}
		printf("\n");
	}
	return 0;
}

//wap to find multiplication of two matrix entered by user.
#include<stdio.h>
int main()
{
	int i,j,k,l,row1,col1,row2,col2;
	printf("Enter the row and column size for first matrix:\n");
	scanf("%d%d",&row1,&col1);
	printf("Enter the row and column size for second matrix:\n");
	scanf("%d%d",&row2,&col2);
	int mat1[row1][col1];
	int mat2[row2][col2];
	int mul[row1][col2];
	//element for first matrix
	printf("Enter an element for first matrix:\n");
	for(i=0; i<row1; i++)
	{
		for(j=0; j<col1; j++)
		{
			scanf("%d",&mat1[i][j]);
		}
	}
	//element for second matrix
		printf("Enter an element for second matrix:\n");
	for(i=0; i<row1; i++)
	{
		for(j=0; j<col1; j++)
		{
			scanf("%d",&mat2[i][j]);
		}
	}
	
	if(col1==row2)
	{ 
		for(i=0; i<row1; i++)
		{
			for(j=0; j<col2; j++)
			{  
			    mul[i][j]=0;
				for(k=0; k<row2; k++)
				{	
					mul[i][j]=mul[i][j]+mat1[i][k]*mat2[k][j];
				}
			
			}
			}	
	}
	else
	{
		printf("For matrix multiplication the column of first matrix must be equal to the row of second matrix.\n");
	}
	
	//print
	printf("The result is:\n");
	for(i=0; i<row1; i++)
		{
			for(j=0; j<col2; j++)
			{
				printf("%d\t",mul[i][j]);
			}
			printf("\n");
			}
	
	return 0;
}
