//wap to sort array in ascending order.
#include<stdio.h>
int main()
{
	int i,j,n,temp;
	printf("Enter the size of an array:");
	scanf("%d",&n);
	int a[n];
	printf("Enter the element for an array:\n");
	for(i=0; i<n; i++)
	{
		scanf("%d",&a[i]);
	}
	for(i=0; i<n; i++)
	{
		for(j=i; j<n; j++)
		{
			if(a[i]>a[j])
			{
				temp=a[i];
				a[i]=a[j];
				a[j]=temp;
			}
		}
	}
	printf("The element in ascending order are:\n");
	for(i=0; i<n; i++)
	{
	printf("%d,",a[i]);	
	}
	return 0;
}


//wap to find second largest element of 1D array
#include<stdio.h>
int main()
{
	int i,j,n,temp;
	printf("Enter the size of an array:");
	scanf("%d",&n);
	int a[n];
	printf("Enter the element for an array:\n");
	for(i=0; i<n; i++)
	{
		scanf("%d",&a[i]);
	}
	for(i=0; i<n; i++)
	{
		for(j=i+1; j<n+1; j++)
		{
			if(a[i]>a[j])
			{
				temp=a[i];
				a[i]=a[j];
				a[j]=temp;
			}
		}
	}
	printf("The second largest number is:%d",a[n-2]);
	return 0;
}

//wap to copy elements of one array to another in reverse order.
#include<stdio.h>
int main()
{
	int i,j,n;
	printf("Enter the size of an array:");
	scanf("%d",&n);
	int a[n];
	int b[n];
	j=n;
	printf("Enter the element for an array:\n");
	for(i=0; i<n; i++)
	{
		scanf("%d",&a[i]);
		b[j-1]=a[i];
		j=j-1;
	}
	printf("The element of an another array in reverse order is:\n");
	for(j=0; j<n; j++)
	{
		printf("%d\n",b[j]);
	}
	return 0;
}

