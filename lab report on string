//wap to convert lowercase to upercase and viceversa for a separate two string.
#include<stdio.h>
#include<string.h>
int main()
{	
	char a[50];
	char b[50];
	printf("Enter string in lowercase:");
	scanf("%50[^\n]s",a);
	printf("Enter string in uppercase:");
	scanf(" %50[^\n]s",b);
	
	strupr(a);
	strlwr(b);
	printf("The lower case entered text into uppercase is: %s\n",a);
	printf("The upper case entered text into lowercase is: %s",b);
	return 0;	
}

//wap to convert lowercase to upercase and viceversa for a single string.
#include<stdio.h>
#include<string.h>
int main()
{	
	char a[50];
	int i;
	printf("Enter string in any case:"); //Aa
	scanf("%50[^\n]s",a);
	while(a[i]!='\0')
	{
		if(a[i]>='a' && a[i]<='z')
		{
			a[i]=a[i]-32;
		}
		else if(a[i]>='A' && a[i]<='Z')
		{
			a[i]=a[i]+32;
		}
		i++;
	}
	printf("The converted string is: %s",a);
	return 0;	
}

