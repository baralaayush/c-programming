//wap to find sum of two complex number input by user using structure.
#include<stdio.h>
struct complex{
	int real;
	int img;
}a,b;

int main()
{	
	int sum_real,sum_img;
	printf("Enter first complex number real part:");
	scanf("%d",&a.real);
	
	printf("Enter first complex number imaginary part:");
	scanf("%d",&a.img);
	
	printf("Enter second complex number real part:");
	scanf("%d",&b.real);
	
	printf("Enter second complex number imaginary part:");
	scanf("%d",&b.img);
	
	sum_real=a.real+b.real;
	sum_img=a.img+b.img;
	
	printf("The sum of complex number is: %d+%di",sum_real,sum_img);
	
}
