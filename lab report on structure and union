//defined structure named circle with member radius. wap to calc area and perimeter of two circle and display result.
#include<stdio.h>
struct circle{
	float radius;
	}c[2];
	
int main()
{
	int i;
	float area,per;
	for(i=0; i<2; i++)
	{
	printf("Enter radius of circle:\n");
	scanf("%f",&c[i].radius);
	}
	
	for(i=0; i<2; i++)
	{
		area=3.1415*c[i].radius*c[i].radius;
		per=2*3.1415*c[i].radius;	
		printf("The area and perimeter of %dst circle is:",i);
		printf("%f,%f",area,per);
		printf("\n");
	}
	return 0;
}


