 //wap to do operation using pointer chain
 #include<stdio.h>
 int main()
 {
 	int a=5;
 	int *x;
	 int **y;
	 int ***z;
 	x=&a;
 	y=&x;
 	z=&y;
 	
 	printf("The value of a=%d\n",a);
 	*x=*x+1;
 	printf("The value of pointer x=%d\n",*x);
 	**y=*x+2;
	printf("The value of pointer y=%d\n",**y);
 	***z=**y+3;
	printf("The value of pointer z=%d\n",***z); 	
	return 0; 
 }
 
