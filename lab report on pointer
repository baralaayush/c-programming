//wap to find factorial of number using recursion function and pointer.
#include<stdio.h>
int fact(int *x);
int main()
{
	int n,*x;
	x=&n;
	printf("Enter any number:");
	scanf("%d",x);
	if(*x<0)
	printf("There is no factorial for negative number");
	else
	{
	printf("The factorial of %d is:%d",*x,fact(x));
}
	return 0;	
	
 } 
 int fact(int *x)
 {  
 
 	int a=*x-1;
 	if(*x>1)
	 {
	 return *x * fact(&a);              
	 }                
 	else
 	{
 	return 1;
	}
 }
 
