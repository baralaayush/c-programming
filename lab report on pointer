//wap to demostrate the use of (&) and (*) operator.
#include<stdio.h>
int main()
{
	int a;
	int *p;
	p=&a;  //linking pointer to normal variable
	*p=12;  //changing value through pointer
	printf("changing value through pointer\n");
	printf("The value in pointer is %d\n",*p);
	printf("The value in normal variable is %d\n",a);
	a=15;  //changing value in normal variable
	printf("changing value in normal variable\n");
	printf("The value in pointer is %d\n",*p);
	printf("The value in normal variable is %d\n",a);
	return 0;
 }
 
