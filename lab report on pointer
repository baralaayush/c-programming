//wap to swap two number using call by refrence.
#include<stdio.h>
int main()
{
	int a,b,*x=&a,*y=&b;
	printf("Enter first number:");
	scanf("%d",x);
	printf("Enter second number:");
	scanf("%d",y);
	*x=*x+*y;
	*y=*x-*y;
	*x=*x-*y;
	printf("The value after swaping are: %d, %d",*x,*y);
	return 0;
}



