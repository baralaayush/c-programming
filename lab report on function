void transpose(int row,int col,int a[row][col])
{
	int b[col][row];
	int i,j;
	for(i=0; i<col; i++)
	{
		for(j=0; j<row; j++)
		{
			b[i][j]=a[j][i];
		}
	}
	
	printf("The transpose of matrix is:\n");
	for(i=0; i<col; i++)
	{
		for(j=0; j<row; j++)
		{
		
		printf("%d\t",b[i][j]);
	}
	printf("\n");
		}
}
