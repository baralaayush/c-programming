//wap to find maximum element of 1d array using function
#include<stdio.h>
int maximum(int a[],int size);
int main()
{
	int size,i,max;
	printf("Enter size of array:");
	scanf("%d",&size);
	int a[size];
	printf("Enter an element:");
	for(i=0; i<size; i++)
	{
		scanf("%d",&a[i]);
		}
	max=maximum(a,size);
	printf("The maximum value of array is:%d",max);
	return 0;
}
int maximum(int a[],int size)
{
	int i,max;
	max=a[0];
	for(i=0; i<size; i++)
	{
		if(max<a[i])
		{
			max=a[i];
		}
	}
	return max;
	
}

