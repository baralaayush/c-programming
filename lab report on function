 //wap to nth term fibonacii using recursion function
 #include<stdio.h>
 int fibo(int);
 int main()
 {
 	int i,n;
 	printf("Enter nth term:");
 	scanf("%d",&n);
 	printf("The fibonacci series upto %d term are=",n);
 	for(i=0; i<n; i++)
 	{
	printf("%d,",fibo(i));
	 }
 	return 0;
 }
 int fibo(int n)
 {
		if(n==0)
		{
 		return 0;
 		}
 		
 		else if (n == 1) {
        return 1;
    }
    
 		else
 		{
 			return fibo(n-1)+fibo(n-2);
		 }
}


