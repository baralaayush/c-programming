//wap to create a function name prime to check whether entered number is prime or not.
#include<stdio.h>
int prime(int a);
int main()
{
	int a,c;
	printf("Enter any number:");
	scanf("%d",&a);
	c=prime(a);
	if(c==1)
	printf("The number is prime");
	else
	printf("The number is not prime");
	return 0;
}
int prime(int a)
{
	int i,count=0;
	for(i=1; i<=a; i++)
	{
		if(a%i==0)
		{
			count=count+1;
		}
	}
	if(count==2)
	return 1;
	else 
	return 0;
}


