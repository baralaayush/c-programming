//wap to reverse a number input by user using function
#include<stdio.h>
int reverse(int num);
int main()
{
	int num,rev;
	printf("Enter any number:");
	scanf("%d",&num);
	rev=reverse(num);
	printf("The number in reverse is: %d",rev);
}
int reverse(int num)
{

 int rem,result=0;
	while(num!=0)
	{
		rem=num%10;
		result=result*10+rem;
		num=num/10;
	}
	return result;
}

