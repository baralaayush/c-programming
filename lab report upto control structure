//wap to input radius of circle and find its perimeter and area both.
#include<stdio.h>
#include<math.h>
#define PIE 3.1415
int main(){
	float r,per,area;
	printf("Enter radius of circle");
	scanf("%f",&r);
	per=2*PIE*r;
	area=PIE*pow(r,2);
	printf("Perimeter of circle is:%f",per);
	printf("Area of circle is:%f",area);	
	return 0;
} 

//wap to find roots of quadratic equation
#include<stdio.h>
#include<math.h>
int main()
{
	float a,b,c;
	float root1,root2;
	printf("Enter value of b");
	scanf("%f",&b);
	printf("Enter value of a");
	scanf("%f",&a);
	printf("Enter value of c");
	scanf("%f",&c);
	
	root1= (-b+sqrt((pow(b,2)-(4*a*c))))/(2*a);
	root2= (-b-sqrt((pow(b,2)-(4*a*c))))/(2*a);
	printf("The value of root are %f%f",root1,root2);
	return 0;
} 

