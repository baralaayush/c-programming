//wap to find whether the number is armstrong number or not
#include<stdio.h>
int main()
{
int n,i, rem, sum = 0;
printf("Enter 3 digit number: ");
scanf("%d", &n);
for( i = n; i > 0; i= i / 10)
{
        rem = i % 10;
        sum = sum + rem * rem * rem;
}
if(sum == n)
        printf("Armstrong number");
    else
        printf("Not Armstrong number");
    return 0;
}

