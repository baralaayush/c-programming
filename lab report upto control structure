//wap to find greatest number among 3 number using ternary operator.
#include<stdio.h>
int main()
{
	int a,b,c,t;
	printf("Enter any three number a,b,c\n");
	scanf("%d%d%d",&a,&b,&c);
	t=(a>b)?((a>c)? a:c) :((b>c)? b:c);
	printf("%d is a greatest number",t);
	return 0;
	} 
	
