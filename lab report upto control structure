		first=second;
		second=next;
		next=first+second;
	}
	
} 

//wap to check the whether the input number is prime or composite.
#include<stdio.h>
int main()
{
	int n;
	int count=0;
	printf("Enter any number:");
	scanf("%d",&n);
	for(int i=1; i<=n; i++)
	{
		if(n%i==0)
		{
			count++;
		}
	}
	if(count==2)
	{
	printf("%d is a prime number",n);}
	else
	{
	printf("%d is a composite number",n);}
	return 0;
} 

